# PostgreSQL（必填）
# 本地 Docker: docker compose up -d db
DATABASE_URL="postgresql://todoplan:todoplan@localhost:5432/todoplan"

AUTH_SECRET="请换成足够长的随机字符串-至少32字符"

# 主站地址与 Host
APP_URL="http://localhost:3000"
APP_HOST="localhost"

# 浏览器 Web Push（npx web-push generate-vapid-keys）
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# 管理员（npm run seed:admin）
ADMIN_EMAIL="admin@todoplan.local"
ADMIN_PASSWORD="请改成强密码"
ADMIN_NAME="管理员"

# 域名验证：仅开发可开
# DOMAIN_VERIFY_SKIP=1
PLATFORM_CNAME_TARGET=""
PLATFORM_SUBDOMAIN_ROOT=""

# 公测推荐托管：Neon / Supabase 的连接串填到 DATABASE_URL
# 示例 Neon:
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ---------- 对象存储 ----------
# local = 写 public/uploads（默认，VPS/Docker）
# r2    = Cloudflare R2（S3 兼容 API）
STORAGE_DRIVER=local

# 仅 STORAGE_DRIVER=r2 时需要：
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=todoplan
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# 或自定义域名 https://cdn.example.com
